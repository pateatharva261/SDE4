{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "presync": "node -e \"console.log('syncing content')\"",
    "sync": "node scripts/sync-content.mjs",
    "predev": "pnpm sync && contentlayer2 build",
    "prebuild": "node -e \"require('fs').existsSync('../platform') && require('child_process').execSync('node scripts/sync-content.mjs', {stdio:'inherit'})\" && node scripts/verify-manifest.mjs && contentlayer2 build",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && tsc --noEmit",
    "check": "pnpm lint && pnpm build"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.20.0",
    "@tailwindcss/typography": "^0.5.20",
    "canvas-confetti": "^1.9.4",
    "cmdk": "^1.1.1",
    "contentlayer2": "^0.5.8",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "next-contentlayer2": "^0.5.8",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.3.3",
    "react-resizable-panels": "^4.12.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
